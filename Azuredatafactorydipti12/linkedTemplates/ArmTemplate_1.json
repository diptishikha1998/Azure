						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     documentForm: 'documentPerLine') ~> dsairport",
						"dimairline derive(country = upper(country)) ~> derivedColumncountry",
						"dimfilight select(mapColumn(",
						"          flight_id,",
						"          flight_number,",
						"          departure_timestamp = departure_time,",
						"          arrival_timestamp = arrival_time",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> selectdimflight",
						"dimpassenger select(mapColumn(",
						"          passenger_id,",
						"          full_name,",
						"          gender_flag = gender,",
						"          age,",
						"          country",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"select1 derive(gender_flag = regexReplace(gender_flag, \"M\", \"Male\")) ~> derivedColumngender",
						"derivedColumngender derive(gender_flag = regexReplace(gender_flag, \"F\", \"Female\")) ~> derivedColumn1",
						"derivedColumn1 filter(age > 25) ~> filter1",
						"filter1 derive(first_name = split(full_name,\" \")[1],",
						"          last_name = split(full_name,\" \")[2]) ~> derivedColumn2",
						"factbookings derive(ticket_cost = toInteger(ticket_cost)) ~> derivedColumn3",
						"dsairport derive(airport_name = lower(airport_name)) ~> derivedColumn4",
						"derivedColumncountry alterRow(upsertIf(1==1)) ~> alterRow1",
						"selectdimflight alterRow(upsertIf(1==1)) ~> alterRow2",
						"derivedColumn2 alterRow(upsertIf(1==1)) ~> alterRow3",
