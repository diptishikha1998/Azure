							"value": "select * from dbo.FactBookings\nwhere booking_date >'@{activity('Lookup_lastload').output.firstRow.lastload}'\nand booking_date <='@{activity('Lookup_latestload').output.firstRow.latestload}'",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
